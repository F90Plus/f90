# =============================================================================
# F90+ - Environment template
# Copy to .env.local and fill in. NEVER commit .env.local (it is gitignored).
# ASCII only, unquoted-friendly: avoid smart quotes when you paste values.
#
# Foundation/tournament phases need NONE of these. Phase 1 (Identity) needs the
# Supabase block. Football keys are optional enrichment (app degrades gracefully).
# =============================================================================

# App - canonical site URL (metadata, OG/Twitter cards, sitemap, robots).
# Local dev: leave as-is. Production (Vercel): https://www.f90.xyz
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Supabase - Phase 1 (auth, profiles, wallet, ledgers, rankings) ----------
# F90+'s OWN isolated project. The publishable key is safe in the browser;
# the secret key is SERVER-ONLY (never expose it client-side, never commit it).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# --- Football data - optional Copilot enrichment (free tier) -----------------
# COPILOT_SOURCE=live AND a key set -> the Analyst uses real form/standings.
# Anything else -> honest Elo-based degradation (numbers are never fabricated).
COPILOT_SOURCE=mock
FOOTBALL_DATA_API_KEY=

# --- Admin sync/settle endpoints (Phase 2+) ----------------------------------
# Required by POST /api/admin/sync-fixtures (and future /settle-fixtures).
# Set a long random string (e.g. openssl rand -hex 32). Add to Vercel env vars
# for production. Never expose this value client-side or commit it.
ADMIN_SYNC_SECRET=

# --- Reserved (NOT read by the code yet - wired in later phases) --------------
# API-Football (free 100/day): rosters + per-match stats for Fantasy (Phase 3).
# API_FOOTBALL_KEY=
